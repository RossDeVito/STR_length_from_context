#!/bin/bash
#SBATCH --job-name=caduceus_predict
#SBATCH --partition=hotel-gpu
#SBATCH --qos=hotel-gpu
#SBATCH --account=htl149
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --gres=gpu:v100:1
#SBATCH --mem=50G
#SBATCH --time=48:00:00
#SBATCH --output=/tscc/projects/ps-gymreklab/rdevito/str_len_pred/slurm_logs/caduceus_predict_%j.out
#SBATCH --error=/tscc/projects/ps-gymreklab/rdevito/str_len_pred/slurm_logs/caduceus_predict_%j.err

# Argument Parsing
MODEL_SAVEDIR=$1
SPLIT=${2:-test}

if [ -z "$MODEL_SAVEDIR" ]; then
    echo "Error: No model savedir provided."
    echo "Usage: sbatch submit_make_predictions_v100.sb <model_savedir> [split]"
    echo " where <model_savedir> is a subdirectory of scripts/training/output/caduceus/"
    echo " and [split] is one of test|val|train (default: test)"
    exit 1
fi

echo "Job $SLURM_JOB_ID started on $(hostname) at $(date)"
echo "Model savedir: $MODEL_SAVEDIR"
echo "Split: $SPLIT"

# Navigate to your project root
PROJECT_ROOT="/tscc/projects/ps-gymreklab/rdevito/str_len_pred/STR_length_from_context/"
cd "$PROJECT_ROOT" || exit 1

# Activate Environment
source ~/.bashrc
conda activate str_pred_caduceus

# Run wrapper script
./scripts/eval_preds/make_predictions.sh "$MODEL_SAVEDIR" "$SPLIT"

echo "Job finished at $(date)"
